{
  "name": "@r2hu1/skate",
  "version": "0.1.0",
  "description": "AI-powered CLI that turns long videos into viral-ready vertical shorts — fully local, no API keys",
  "type": "module",
  "bin": {
    "skate": "./src/index.ts"
  },
  "files": [
    "src",
    "scripts",
    "package.json",
    "README.md",
    "tsconfig.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/r2hu1/skate"
  },
  "homepage": "https://github.com/r2hu1/skate",
  "bugs": {
    "url": "https://github.com/r2hu1/skate/issues"
  },
  "keywords": [
    "shorts",
    "vertical",
    "video",
    "clip",
    "youtube",
    "ai",
    "whisper",
    "ollama",
    "ffmpeg"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "setup-python": "mkdir -p ~/.skate && python3 -m venv ~/.skate/venv && ~/.skate/venv/bin/pip3 install -r scripts/requirements.txt"
  },
  "dependencies": {
    "ora": "^9.4.0"
  }
}
